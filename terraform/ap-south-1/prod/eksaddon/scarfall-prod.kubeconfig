apiVersion: v1
clusters:
- cluster:
    server: https://4AB2AE330473921D24553562901E2327.gr7.ap-south-1.eks.amazonaws.com
    certificate-authority-data: 
  name: kubernetes
contexts:
- context:
    cluster: kubernetes
    user: aws
  name: aws
current-context: aws
kind: Config
preferences: {}
users:
- name: aws
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1beta1
      args:
      - --region
      - ap-south-1
      - eks
      - get-token
      - --cluster-name
      - scarfall-prod
      command: aws
      env:
      - name: AWS_PROFILE
        value: scarfall-prod
